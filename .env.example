# Supabase - get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# API-Football - get from https://www.api-football.com/
# Free tier: 100 requests/day
API_FOOTBALL_KEY=your-api-football-key-here

# Groq API - get from https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# Canonical site URL for metadata, sitemap and OG images (optional)
# Falls back to the Vercel deployment URL, then localhost
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
